#!/bin/bash
#SBATCH --job-name=rmlp_sep_lmdb_prev
#SBATCH --partition=normal
#SBATCH --cpus-per-task=4
#SBATCH --mem=8000
#SBATCH --time=00:20:00
#SBATCH --qos=medium
#SBATCH --output=/slurm-storage/shucli/PROJECT_FOLDER/DMD2/experiments/RandomMLPMfldSep/logs/preview_lmdb_%j.out
#SBATCH --error=/slurm-storage/shucli/PROJECT_FOLDER/DMD2/experiments/RandomMLPMfldSep/logs/preview_lmdb_%j.err

PROJECT_ROOT="${PROJECT_ROOT:-/slurm-storage/shucli/PROJECT_FOLDER}"
DMD2_ROOT="${DMD2_ROOT:-${PROJECT_ROOT}/DMD2}"
export CHECKPOINT_PATH="${CHECKPOINT_PATH:-${PROJECT_ROOT}/DATA/DMD2_OT/model_checkpoints}"
export LMDB="${LMDB:-$CHECKPOINT_PATH/random_mlp_manifold_sep-32x32_lmdb}"
export OUT="${OUT:-${DMD2_ROOT}/experiments/RandomMLPMfldSep/randommlpmfld_sep_lmdb_preview.png}"
source /slurm-storage/miniconda3/etc/profile.d/conda.sh && conda activate dmd2_h100
cd "${DMD2_ROOT}" && export PYTHONPATH=$PWD:$PYTHONPATH
mkdir -p "$(dirname "${OUT}")" "${DMD2_ROOT}/experiments/RandomMLPMfldSep/logs"
python experiments/MNIST/eval_tools/preview_lmdb_grid.py "$LMDB" -o "$OUT"
