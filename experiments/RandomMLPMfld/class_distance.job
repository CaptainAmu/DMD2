#!/bin/bash
#SBATCH --job-name=random_mlpmfld_class_distance
#SBATCH --partition=h100
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --gres=gpu:1
#SBATCH --cpus-per-task=8
#SBATCH --mem=64000
#SBATCH --time=4:00:00
#SBATCH --qos=medium
#SBATCH --output=/slurm-storage/shucli/PROJECT_FOLDER/DMD2/experiments/RandomMLPMfld/logs/class_distance_%j.out
#SBATCH --error=/slurm-storage/shucli/PROJECT_FOLDER/DMD2/experiments/RandomMLPMfld/logs/class_distance_%j.err

export CHECKPOINT_PATH="/slurm-storage/shucli/PROJECT_FOLDER/DATA/DMD2_OT/model_checkpoints"
DMD2_ROOT="/slurm-storage/shucli/PROJECT_FOLDER/DMD2"
export TEACHER_PKL="${TEACHER_PKL:-${CHECKPOINT_PATH}/randommlpmfld_edm_teacher_runs/00000-random-mlp-manifold-32x32-cond-adm-edm-gpus1-batch32-fp32-mnist_edm_teacher/network-snapshot-003225.pkl}"
OUT_DIR="${DMD2_ROOT}/experiments/RandomMLPMfld/class_distance"

PYTHON=/slurm-storage/shucli/.conda/envs/dmd2_h100/bin/python

cd /slurm-storage/shucli/PROJECT_FOLDER/DMD2
export PYTHONPATH=/slurm-storage/shucli/PROJECT_FOLDER/DMD2:$PYTHONPATH
mkdir -p /slurm-storage/shucli/PROJECT_FOLDER/DMD2/experiments/RandomMLPMfld/logs
mkdir -p "${OUT_DIR}"

$PYTHON experiments/RandomMLPMfld/eval_tools/class_distance.py \
  --teacher_pkl "${TEACHER_PKL}" \
  --out_dir     "${OUT_DIR}" \
  --batch_size  20 \
  --resolution  32 \
  --label_dim     10 \
  --img_channels  1 \
  --num_per_class 50 \
  --seed          0 \
  --num_steps     1
